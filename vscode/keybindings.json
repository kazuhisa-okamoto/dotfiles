// 既定値を上書きするには、このファイル内にキー バインドを挿入します
[
    { 
        "key": "ctrl+j", 
        "command": "extension.vim_escape",
        "when": "editorTextFocus && vim.active && !inDebugRepl" 
    },

    // タブの切り替え
    {
        "key": "ctrl+shift+tab",
        "command": "workbench.action.previousEditor"
    },
    {
        "key": "ctrl+pageup",
        "command": "-workbench.action.previousEditor"
    },
    {
        "key": "ctrl+tab",
        "command": "workbench.action.nextEditor"
    },
    {
        "key": "ctrl+pagedown",
        "command": "-workbench.action.nextEditor"
    }, 
  
    // OpenEditorに移動
    {
        "key": "ctrl+l",
        "command": "workbench.files.action.focusOpenEditorsView",
        "when": "!filesExplorerFocus",
    },
    {
        // Explorerから戻るときにExplorerを閉じる
        "command" : "runCommands",
        "key": "ctrl+l",
        "args" : {
            "commands": [
                "workbench.view.explorer",               
                "workbench.action.toggleSidebarVisibility"
            ]
        },
        "when": "explorerViewletFocus && explorerViewletVisible && !inputFocus",
    },

    // ターミナルとエディタ間を移動(ターミナルを閉じない) ";"と書いているが":"にセットされている.
    { "key": "ctrl+;",
      "command": "workbench.action.terminal.focus",
      "when": "editorTextFocus"
    },
    {
      "key": "ctrl+;",
      "command": "workbench.action.focusFirstEditorGroup",
      "when": "terminalFocus"
    },

    // ctrl+@ のneovimショートカットを削除. ctrl+@でターミナルを開く.
    {
      "key": "ctrl+oem_3",
      "command": "-vscode-neovim.escape",
      "when": "editorTextFocus && neovim.init && editorLangId not in 'neovim.editorLangIdExclusions'"
    }

    // ウィンドウ移動. vimではウィンドウの入れ替えだがウィンドウの移動に変更.
    {
        "key": "ctrl+k l",
        "command": "workbench.action.moveEditorToNextGroup",
        //"when": "!editorTextFocus && !terminalFocus && neovim.mode != 'cmdline'"
    },
    {
        "key": "ctrl+k h",
        "command": "workbench.action.moveEditorToPreviousGroup",
        //"when": "!editorTextFocus && !terminalFocus && neovim.mode != 'cmdline'"
    },
    {
        "key": "ctrl+k k",
        "command": "workbench.action.moveEditorToAboveGroup",
        //"when": "!editorTextFocus && !terminalFocus && neovim.mode != 'cmdline'"
    },
    {
        "key": "ctrl+k j",
        "command": "workbench.action.moveEditorToBelowGroup",
        //"when": "!editorTextFocus && !terminalFocus && neovim.mode != 'cmdline'"
    },

    // 全選択
    {   
        "key": "ctrl+a",
        "command": "editor.action.selectAll" 
    },

    {
        "key": "alt+f",
        "command": "actions.find",
        "when": "editorFocus || editorIsOpen" 
    },
    {
        "key": "ctrl+c",
        "command": "editor.action.clipboardCopyAction"
    },
  
    // tex
    {
      	"key": "ctrl+alt+b",
      	"command": "latex-workshop.build",
      	"when": "resourceLangId == latex"
    },
    {
      	"key": "ctrl+alt+c",
      	"command": "latex-workshop.clean",
      	"when": "resourceLangId == latex"
    },
    {
      	"key": "ctrl+alt+s",
      	"command": "latex-workshop.synctex",
      	"when": "resourceLangId == latex"
    },

    // リプレース
    // ノーマルモードでのctrl+hのvimキーを除外. vscodeのリプレースを有効にする
    {
        "key": "ctrl+h",
        "command": "-vscode-neovim.send",
        "when": "editorTextFocus && neovim.ctrlKeysNormal.h && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
    },

    // github copilot
    {
        "key": "ctrl+o",
        "command": "workbench.panel.chat.view.copilot.focus",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+o",
        "command":"workbench.action.focusActiveEditorGroup",
        "when": "view.workbench.panel.chat.view.copilot.visible && !editorFocus"
    },
    {
        "key": "ctrl+o",
        "command": "-workbench.action.files.openFile",
        "when": "true"
    },
    

    // 定義へ移動, 宣言へ移動, 実装へ移動, 参照へ移動
    {
        "key": "ctrl+g d",
        "command": "editor.action.revealDefinition",
        "when": "editorTextFocus && neovim.mode == 'normal' && !yazi.active"
    },
    {
        "key": "ctrl+g ctrl+d", 
        "command": "editor.action.revealDeclaration",
        "when": "editorTextFocus && neovim.mode == 'normal'"
    },
    {
        "key": "ctrl+g i",
        "command": "editor.action.goToImplementation",
        "when": "editorTextFocus && neovim.mode == 'normal'"
    },
    {
        "key": "ctrl+g r",
        "command": "editor.action.goToReferences",
        "when": "editorTextFocus && neovim.mode == 'normal'"
    },
    
    // ターミナルをエディタペインで開く
    {
        "key": "ctrl+t", 
        "command": "workbench.action.createTerminalEditor"
    },
    // ターミナルペインでvimのウィンドウ移動と同じキーでエディタペインに移動できるようにする
    {
        "key": "ctrl+w w",
        "command": "workbench.action.focusNextGroup",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+w ctrl+w",
        "command": "workbench.action.focusNextGroup",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+w h",
        "command": "workbench.action.focusPreviousGroup",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+w l",
        "command": "workbench.action.focusNextGroup",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+w j",
        "command": "workbench.action.focusBelowGroup",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+w k",
        "command": "workbench.action.focusAboveGroup",
        "when": "terminalFocus"
    },
    {
      "key": "ctrl+w q",
      "command": "workbench.action.closeActiveEditor",
      "when": "!editorTextFocus && !filesExplorerFocus && !searchViewletFocus && neovim.mode != 'cmdline'"
    }
]